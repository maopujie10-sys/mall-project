# Auto detect text files and prevent CRLF corruption
* text=auto

# Python files must stay LF
*.py text eol=lf

# Frontend files
*.vue text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf
Dockerfile* text eol=lf
.dockerignore text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.woff binary
*.woff2 binary