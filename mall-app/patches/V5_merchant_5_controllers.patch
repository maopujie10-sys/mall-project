+
+        Map<String, Object> data = new HashMap<>();
+        data.put("pageInfo", Map.of("pageNum", pageNum, "pageSize", pageSize, "totalElements", result.getTotal()));
+        data.put("pageList", list);
+        return Result.ok(data);
