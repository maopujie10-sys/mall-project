# ============================================
# Friday AI OS — 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ============================================

# 运行环境: development | staging | production
APP_ENV=development

# ===== Agent Token（生产环境必须设置）=====
X_AGENT_TOKEN=your-secret-token-here

# ===== AI 模型 =====
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# ===== 数据库 =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=agent_user
DB_PASSWORD=
DB_NAME=ai_agent

# ===== 商城数据库 =====
MALL_DB_HOST=127.0.0.1
MALL_DB_PORT=3306
MALL_DB_USER=root
MALL_DB_PASSWORD=
MALL_DB_NAME=mall_db

# ===== Redis =====
REDIS_DSN=redis://localhost:6379/0

# ===== 腾讯云 COS（图片存储）=====
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=shangchengtupian-1435149418
COS_REGION=ap-singapore

# ===== 通知 =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=
DINGTALK_WEBHOOK=
WECOM_WEBHOOK=

# ===== SSH（远程执行）=====
SSH_HOST=
SSH_PORT=22
SSH_USER=root
SSH_KEY_PATH=

# ===== AI Factory =====
IMAGE_API_KEY=
IMAGE_API_URL=https://api.openai.com/v1/images/generations
VIDEO_API_KEY=
VIDEO_API_URL=https://api.runwayml.com/v1/generations

# ===== 商城 API =====
MALL_BASE_URL=http://mall-app:8080
CUSTOMER_BASE_URL=
ROTATION_BASE_URL=

# ===== 路径 =====
BACKUP_DIR=./backups
LOG_DIR=./logs

# ===== CORS（生产环境设置具体域名）=====
CORS_ORIGINS=*
