# ===== Friday AI OS 环境配置 =====
# 复制此文件为 .env 并填写你的密钥

# 环境: development / staging / production
APP_ENV=development
# ===== 数据目录（Docker部署时自动配置，无需修改）=====
APP_STATE_DIR=
APP_MEMORY_DIR=
APP_DATA_DIR=


# ===== AI 模型 (选一个即可) =====
# Claude (Anthropic)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# DeepSeek (国内、便宜)
DEEPSEEK_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Ollama 本地模型 (免费、离线)
# 安装: https://ollama.com → ollama pull qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434
# ===== GitHub MCP =====
GITHUB_TOKEN=your_github_token_here

# ===== Vision API =====
IMAGGA_API_KEY=your_imagga_api_key_here

OLLAMA_MODEL=qwen2.5:14b

# ===== 数据库 =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=agent_user
DB_PASSWORD=
DB_NAME=ai_agent

# 商城数据库
MALL_DB_HOST=127.0.0.1
MALL_DB_PORT=3306
MALL_DB_USER=agent_user
MALL_DB_PASSWORD=
MALL_DB_NAME=mall_db

# ===== 外部服务 =====
MALL_BASE_URL=http://mall-app:8080

# ===== 腾讯云 COS (图片存储) =====
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=shangchengtupian-1435149418
COS_REGION=ap-singapore
COS_DOMAIN=https://shangchengtupian-1435149418.cos.ap-singapore.myqcloud.com

# ===== 通知渠道 =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=
DINGTALK_WEBHOOK=
WECOM_WEBHOOK=

# ===== SSH =====
SSH_HOST=
SSH_PORT=22
SSH_USER=agent_user
SSH_KEY_PATH=

# ===== Agent Token (生产环境必须改) =====
X_AGENT_TOKEN=change-me-in-production

# ===== AI 作图/视频 =====
IMAGE_API_KEY=
VIDEO_API_KEY=
