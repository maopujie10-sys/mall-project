# TikTokMall AI Agent — 环境变量配置
# 复制此文件为 .env 后修改

# ===== 运行环境 =====
APP_ENV=development
APP_PORT=9000

# ===== Agent Token（必填，生产环境必须修改）=====
X_AGENT_TOKEN=change-me-in-production

# ===== Claude API =====
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# ===== 外部服务地址 =====
MALL_BASE_URL=http://mall-app:8080
CUSTOMER_BASE_URL=
ROTATION_BASE_URL=

# ===== AI Agent 数据库 =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=agent_user
DB_PASSWORD=
DB_NAME=ai_agent

# ===== 商城数据库（用于直接SQL查询和备份）=====
MALL_DB_HOST=127.0.0.1
MALL_DB_PORT=3306
MALL_DB_USER=root
MALL_DB_PASSWORD=
MALL_DB_NAME=mall_db

# ===== Redis =====
REDIS_DSN=redis://localhost:6379/0

# ===== SSH 远程服务器 =====
SSH_HOST=45.192.97.37
SSH_PORT=22
SSH_USER=agent_user
SSH_KEY_PATH=/opt/claude-agent-control/keys/agent_key

# ===== AI 内容工厂 =====
IMAGE_API_KEY=
IMAGE_API_URL=https://api.openai.com/v1/images/generations
VIDEO_API_KEY=
VIDEO_API_URL=https://api.runwayml.com/v1/generations

# ===== 通知渠道 =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=
DINGTALK_WEBHOOK=
WECOM_WEBHOOK=

# ===== 路径 =====
BACKUP_DIR=/opt/claude-agent-control/backups
LOG_DIR=/opt/claude-agent-control/logs

# ===== 腾讯云 COS 图片存储 =====
COS_SECRET_ID=AKIDGOp490g9NOCuPgkbFhwqX1qePzMXVGo9
